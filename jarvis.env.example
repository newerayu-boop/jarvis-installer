# ══════════════════════════════════════════════════════
#   JARVIS — Настройка (заполни ВСЕ поля со звёздочкой *)
# ══════════════════════════════════════════════════════

# ★ Имя твоего бота (напиши @botusername из BotFather)
BOT_USERNAME="my_jarvis_bot"

# ★ Токен бота (из @BotFather → /newbot)
TELEGRAM_TOKEN="1234567890:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ★ Твой Telegram ID (узнай у @userinfobot)
OWNER_TELEGRAM_ID="123456789"

# ★ Твоё имя (как Джарвис будет тебя называть)
OWNER_NAME="Александр"

# ★ Имя ассистента
BOT_NAME="Джарвис"

# ═══════════════ AI МОДЕЛИ ═══════════════

# ★ OpenRouter API Key (бесплатно: openrouter.ai → Keys)
OPENROUTER_KEY="sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ★ Groq API Key (бесплатно: console.groq.com → API Keys)
GROQ_KEY="gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Aisha STT Key (опционально, лучше для узбекского: aisha.group)
# Если не заполнено — будет использоваться только Groq Whisper
AISHA_KEY=""

# ═══════════════ МОДЕЛЬ ═══════════════

# Модель (можно оставить по умолчанию, работает бесплатно)
AI_MODEL="openrouter/openai/gpt-4o-mini"

# ═══════════════ ЯЗЫК ═══════════════

# Основной язык общения: ru (русский) или uz (узбекский)
BOT_LANGUAGE="ru"
